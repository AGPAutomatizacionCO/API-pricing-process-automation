APP_NAME=AGP Pricing Process API
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000

# Azure App Service Easy Auth
# En Azure, la identidad llega por headers X-MS-*.
# En local se puede habilitar modo desarrollo para simular usuario.
EASY_AUTH_ENABLED=true
LOCAL_AUTH_ENABLED=true
LOCAL_AUTH_EMAIL=miuser@agpglass.com
LOCAL_AUTH_NAME=Usuario Local

# SQL Server / Azure SQL
SQL_SERVER=
SQL_DATABASE=
SQL_DRIVER=ODBC Driver 17 for SQL Server
SQL_TRUSTED_CONNECTION=false
SQL_USERNAME=
SQL_PASSWORD=

# CORS
# En producción agregar solo los dominios reales permitidos.
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Access policy
ACCESS_POLICY_ENABLED=true
ADMIN_USERS=miuser@agpglass.com
ANALYST_USERS=
VIEWER_USERS=

# Future: Microsoft Entra groups
ADMIN_GROUPS=
ANALYST_GROUPS=
VIEWER_GROUPS=

# Logging
LOG_LEVEL=INFO
AUDIT_LOG_ENABLED=true